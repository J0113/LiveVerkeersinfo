      "safety_risk": "Nearest-line matching can select the opposite carriageway after lateral GPS error.",
      "fixes": [
        {"timestamp_ms": 1000, "coordinates": [4.90003, 52.00035], "heading": 1, "speed_mps": 25, "accuracy_m": 7, "allowed_statuses": ["accepted", "ambiguous"], "expected_segment_ids": ["dual-a4-north"]},
