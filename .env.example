OSM_IMPORT_BATCH_SIZE=5000
ROAD_SPEED_STALE_AFTER_S=600
ROAD_SPEED_PROPAGATION_MAX_M=1500
ROAD_SPEED_INTERPOLATION_MAX_M=5000
ROAD_MATRIX_STALE_AFTER_S=180
ROAD_DRIP_STALE_AFTER_S=180
SOURCE_BINDING_VILD_MAX_DISTANCE_M=50
