DATABASE_URL=postgresql+psycopg://ndwinfo:ndwinfo@localhost:5432/ndwinfo
NDW_BASE_URL=https://opendata.ndw.nu
DATA_DIR=./data
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=2
DB_POOL_RECYCLE_S=1800
POLLER_MAX_WORKERS=3
POLLER_BULK_MAX_INFLIGHT=1
POLLER_IDLE_TIMEOUT_S=300
POLLER_MAINTENANCE_IDLE_S=900
